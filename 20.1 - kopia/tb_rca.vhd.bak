library IEEE;
use IEEE.std_logic_1164.all;

entity tb_rca is
end entity tb_rca;

architecture BEHAVORIAL of tb_rca is

component rca

    port(A, B: in std_logic_vector(3 downto 0);
        cin: in std_logic;
        cout: out std_logic;
        O: out std_logic_vector(3 downto 0)
    );
end component;

signal a_tb: std_logic_vector(3 downto 0):= (others => '0');
signal b_tb: std_logic_vector(3 downto 0):= (others => '0');
signal cin_tb: std_logic := '0';
signal cout_tb: std_logic := '0';
signal o_tb: std_logic_vector(3 downto 0) := (others => '0');

begin
DUT: entity work.rca
    port map (
        A => a_tb,  
        B => b_tb,
	cin => cin_tb,
        cout => cout_tb,
        O => o_tb);

 Testing: PROCESS
 BEGIN
 
    a_tb <= "0001";
    b_tb <= "0001";
    cin_tb <= '0';
    wait for 10 ns;

    a_tb <= "0101";
    b_tb <= "1010";
    cin_tb <= '1';
    wait for 10 ns;

    a_tb <= "1111";
    b_tb <= "1111";
    cin_tb <= '0';
    wait for 10 ns;

    a_tb <= "1111";
    b_tb <= "1111";
    cin_tb <= '1';
    wait for 10 ns;

 END PROCESS;
END architecture BEHAVORIAL;
   
